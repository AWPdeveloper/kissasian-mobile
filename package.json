{
  "name": "kissasian-mobile",
  "version": "1.0.0",
  "description": "KissAsian Mobile - Watch Asian Dramas",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "jest --watch",
    "lint": "eslint .",
    "build:android": "eas build --platform android",
    "build:android:local": "npx expo export --platform android --output-dir ./dist && cd dist/android && ./gradlew assembleRelease",
    "build:ios": "eas build --platform ios",
    "build:all": "eas build --platform all",
    "submit:android": "eas submit --platform android",
    "submit:ios": "eas submit --platform ios",
    "preview": "eas build --platform android --profile preview"
  },
  "dependencies": {
    "@expo/ui": "57.0.3",
    "@react-navigation/bottom-tabs": "^7.18.7",
    "@react-navigation/native": "^7.3.7",
    "@react-navigation/native-stack": "^7.17.9",
    "@react-native-async-storage/async-storage": "^3.1.1",
    "axios": "^1.18.1",
    "cheerio": "^1.2.0",
    "expo": "57.0.2",
    "expo-constants": "57.0.3",
    "expo-device": "57.0.0",
    "expo-font": "57.0.0",
    "expo-glass-effect": "57.0.0",
    "expo-image": "57.0.0",
    "expo-linking": "57.0.1",
    "expo-notifications": "57.0.3",
    "expo-router": "57.0.3",
    "expo-splash-screen": "57.0.2",
    "expo-status-bar": "57.0.0",
    "expo-symbols": "57.0.0",
    "expo-system-ui": "57.0.0",
    "expo-task-manager": "57.0.2",
    "expo-web-browser": "57.0.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "2.32.0",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-sqlite-storage": "^6.0.1",
    "react-native-video": "^6.19.2",
    "react-native-web": "0.21.2",
    "react-native-worklets": "0.10.0"
  },
  "devDependencies": {
    "@types/react": "19.2.17",
    "@types/react-native": "^0.73.0",
    "eas-cli": "^20.5.1",
    "typescript": "6.0.3"
